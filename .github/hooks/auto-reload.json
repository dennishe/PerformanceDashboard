{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/mark-main-session.sh",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/mark-changed.sh",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/reload-if-changed.sh",
        "timeout": 15
      }
    ]
  }
}
